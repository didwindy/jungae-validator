# ─────────────────────────────────────────────────────────────────────────────
# 중개대상물 광고 검증 시스템 — API 키 설정
# 이 파일을 복사해서 .env 파일로 저장하고 실제 키를 입력하세요.
# ─────────────────────────────────────────────────────────────────────────────

# ① 공공데이터포털 (https://data.go.kr)
#    "건축HUB 건축물대장정보 서비스" 검색 → 활용 신청 → 일반 인증키 복사
BUILDING_HUB_KEY=여기에_건축HUB_인증키_입력

# ② 브이월드 (https://api.vworld.kr)
#    회원가입 → 인증키 신청 (개발키 3개월 / 운영키 별도 심사)
#    이 키 하나로 두 가지 모두 처리:
#      - 주소검색 Geocoder: 지번 → 시군구코드/법정동코드/본번/부번
#      - 토지임야정보: 2024.01부터 data.go.kr에서 VWorld로 이전
VWORLD_KEY=여기에_VWorld_API키_입력

# VWorld NED API 도메인 (토지임야정보용)
# 발급 시 등록한 도메인을 입력하세요.
# 로컬 테스트: localhost  /  실서버: yourdomain.com
VWORLD_DOMAIN=localhost

# 카카오 REST API 키 (주소 검색용 — 해외 서버에서도 작동)
# 발급: https://developers.kakao.com → 앱 만들기 → REST API 키
KAKAO_REST_KEY=여기에_카카오REST키_입력
